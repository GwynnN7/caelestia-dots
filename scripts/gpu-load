#!/usr/bin/env bash

QUIET=false
if [ "$1" = "-q" ] || [ "$1" = "--quiet" ]; then
    QUIET=true
fi

GPU_PATH=$(ls -d /sys/class/drm/card*/device 2>/dev/null | head -n 1)

UTIL=""
if [ -f "$GPU_PATH/gpu_busy_percent" ]; then
    UTIL=$(cat "$GPU_PATH/gpu_busy_percent" 2>/dev/null)
fi

if [ -z "$UTIL" ]; then
    if [ "$QUIET" = true ]; then
        echo 0
    else
        echo "Error: Could not find GPU utilization sensor."
    fi
    exit 0
fi



HWMON_DIR=$(ls -d $GPU_PATH/hwmon/hwmon* 2>/dev/null | head -n 1)

if [ -z "$HWMON_DIR" ]; then
    if [ "$QUIET" = true ]; then
        echo "$UTIL"
    else
        echo "Error: Could not find hwmon directory for power sensors."
    fi
    exit 0
fi



POWER_CUR=""
if [ -f "$HWMON_DIR/power1_average" ]; then
    POWER_CUR=$(cat "$HWMON_DIR/power1_average" 2>/dev/null)
elif [ -f "$HWMON_DIR/power1_input" ]; then
    POWER_CUR=$(cat "$HWMON_DIR/power1_input" 2>/dev/null)
fi

if [ -z "$POWER_CUR" ]; then
    if [ "$QUIET" = true ]; then
        echo "$UTIL"
    else
        echo "Error: Could not find current power draw sensor."
    fi
    exit 0
fi



POWER_MAX=""
if [ -f "$HWMON_DIR/power1_cap" ]; then
    POWER_MAX=$(cat "$HWMON_DIR/power1_cap" 2>/dev/null)
fi

if [ -z "$POWER_MAX" ]; then
    if [ "$QUIET" = true ]; then
        echo "$UTIL"
    else
        echo "Error: Could not find max power cap sensor."
    fi
    exit 0
fi



EFFECTIVE_LOAD=$(awk -v util="$UTIL" -v cur="$POWER_CUR" -v max="$POWER_MAX" 'BEGIN {
    # Protect against division by zero
    if (max <= 0) {
        print 0;
        exit;
    }
    
    power_factor = cur / max;
    effective = util * power_factor;
    
    # Clamp to 100% maximum
    if (effective > 100) {
        effective = 100;
    }
    
    # Output as an integer to mimic nvtop
    printf "%d\n", effective;
}' 2>/dev/null)


if [ -z "$EFFECTIVE_LOAD" ]; then
    EFFECTIVE_LOAD="$UTIL"
fi

if [ "$QUIET" = true ]; then
    echo "$EFFECTIVE_LOAD"
else
    echo "Standard Utilization: ${UTIL}%"
    echo "Power Factor: $(awk "BEGIN {printf \"%.2f\", $POWER_CUR/$POWER_MAX}")"
    echo "Effective Load: ${EFFECTIVE_LOAD}%"
fi
