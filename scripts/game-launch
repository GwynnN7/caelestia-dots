#!/usr/bin/env bash

# --- 1. Default States ---
NVAPI=0
MANGOAPP=0
USE_X11=0
GAME_CMD=()

# --- 2. Strict Argument Parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --nvapi)
            NVAPI=1
            shift
            ;;
        --no-nvapi)
            NVAPI=2
            shift
            ;;
        --mangoapp)
            MANGOAPP=1
            shift
            ;;
        --x11)
            USE_X11=1
            shift
            ;;
        --)
            shift
            GAME_CMD+=("$@")
            break
            ;;
        -*)
            echo "Error: Unknown or unsupported flag '$1' provided to game-launch."
            echo "Supported flags: --nvapi, --no-nvapi, --mangoapp, --x11"
            exit 1
            ;;
        *)
            GAME_CMD+=("$@")
            break
            ;;
    esac
done

if [ ${#GAME_CMD[@]} -eq 0 ]; then
    echo "Error: No game executable provided."
    exit 1
fi

# --- 3. Game Environment Variables (Proton/Wine) ---
GAME_ENV=(
    LD_PRELOAD="$LD_PRELOAD"
    PROTON_PRIORITY_HIGH=1 
    ENABLE_LAYER_MESA_ANTI_LAG=1
)

if [ "$NVAPI" = "1" ]; then
    GAME_ENV+=(PROTON_ENABLE_NVAPI=1)
elif [ "$NVAPI" = "2" ]; then
    GAME_ENV+=(PROTON_DISABLE_NVAPI=1)
fi

if [ "$USE_X11" = "0" ]; then
    GAME_ENV+=(PROTON_ENABLE_WAYLAND=1)
fi

# --- 4. Gamescope Compositor Arguments ---
GAMESCOPE_ARGS=(
    -W 1920 -H 1080 -f -r 165 
    --adaptive-sync --rt 
    --force-grab-cursor
)

if [ "$USE_X11" = "0" ]; then
    GAMESCOPE_ARGS+=(--expose-wayland)
fi

if [ "$MANGOAPP" = "1" ]; then
    GAMESCOPE_ARGS+=(--mangoapp)
    INNER_WRAPPER=()
else
    INNER_WRAPPER=(mangohud)
fi

# --- 5. Assemble Launch Command ---
LAUNCH_CMD=(
    env LD_PRELOAD="" gamemoderun gamescope "${GAMESCOPE_ARGS[@]}" -- env "${GAME_ENV[@]}" "${INNER_WRAPPER[@]}" "${GAME_CMD[@]}"
)

# --- 6. Execution ---
if ! powerprofilesctl list | grep -q 'performance:'; then 
    exec "${LAUNCH_CMD[@]}"
else 
    if [ -n "$GAME_PERFORMANCE_SCREENSAVER_ON" ]; then 
        exec powerprofilesctl launch -p performance -r "CachyOS wrapper" -- "${LAUNCH_CMD[@]}"
    else 
        exec systemd-inhibit --why "Gaming" powerprofilesctl launch -p performance -r "CachyOS wrapper" -- "${LAUNCH_CMD[@]}"
    fi
fi
