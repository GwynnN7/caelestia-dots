pkgname=hypr-kdeconnect-fix
pkgver=1.0.0
pkgrel=1
pkgdesc="A fix for KDE Connect on Hyprland"
arch=('x86_64')
url="https://github.com/gfhdhytghd/hypr-kdeconnect-fix"
license=('MIT')

depends=('qt6-base' 'wayland' 'libxkbcommon' 'libei' 'xdg-desktop-portal')
makedepends=('cmake' 'pkgconf' 'git')

source=("$pkgname::git+$url.git")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/${pkgname}"

    cmake -S . -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr

    cmake --build build -j"$(nproc)"
}

check() {
    cd "${srcdir}/${pkgname}"
    ctest --test-dir build --output-on-failure
}

package() {
    cd "${srcdir}/${pkgname}"

    DESTDIR="$pkgdir" cmake --install build

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}