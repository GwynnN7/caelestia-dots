    "lock": {
        "profilePicShape": 18
    },
    "notifs": {
        "actionOnClick": true,
        "defaultExpireTimeout": 4000
    },
    "osd": {
        "enableBrightness": true,
        "enableMicrophone": true,
        "enabled": true,
        "hideDelay": 1000
    },
    "paths": {
        "lyricsDir": "~/Music/Lyrics",
        "mediaGif": "root:/assets/toothless.gif",
        "sessionGif": "root:/assets/cortana.png",
        "wallpaperDir": "~/Pictures/Wallpaper"
    },
    "services": {
        "defaultPlayer": "tidal-hifi",
        "lyricsBackend": "Auto",
        "visualiserBars": 60,
        "weatherLocation": "Orvieto"
    },
    "session": {
        "commands": {
            "automode": [
                "sh",
                "-c",
                "cortana service &>/dev/null && cortana api -val 0 settings/automaticmode | cortana notify"
            ],
            "generic": [
                "sh",
                "-c",
                "cortana service &>/dev/null && cortana api -act toggle devices/generic | cortana notify"
            ],
            "lamp": [
                "sh",
                "-c",
                "cortana service &>/dev/null && cortana api -act toggle devices/lamp | cortana notify"
            ],
            "logout": [
                "uwsm",
                "stop"
            ],
            "reboot": [
                "sh",
                "-c",
                "cortana service &>/dev/null && cortana api -cmd reboot computer | cortana notify || systemctl reboot"
            ],
            "shutdown": [
                "sh",
                "-c",
                "cortana service &>/dev/null && cortana api -cmd shutdown computer | cortana notify || systemctl poweroff"
            ]
        }
    },
    "shimeji": {
        "enabled": false
