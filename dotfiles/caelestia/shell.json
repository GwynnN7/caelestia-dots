{
    "appearance": {
        "spacing": {
            "scale": 0.9
        },
        "transparency": {
            "base": 0.93,
            "enabled": true,
            "layers": 0.3
        }
    },
    "bar": {
        "activeWindow": {
            "compact": true,
            "inverted": false,
            "showOnHover": true
        },
        "clock": {
            "background": false,
            "showDate": true,
            "showIcon": false
        },
        "popouts": {
            "activeWindow": true,
            "statusIcons": true,
            "tray": true
        },
        "scrollActions": {
            "brightness": true,
            "volume": true,
            "workspaces": true
        },
        "status": {
            "showAudio": false,
            "showBattery": true,
            "showBluetooth": true,
            "showKbLayout": false,
            "showLockStatus": true,
            "showMicrophone": true,
            "showNetwork": true,
            "showWifi": true
        },
        "tray": {
            "background": false,
            "compact": false,
            "recolour": false
        },
        "workspaces": {
            "maxWindowIcons": 4,
            "occupiedBg": false,
            "shown": 4
        }
    },
    "general": {
        "idle": {
            "inhibitWhenAudio": true,
            "lockBeforeSleep": true,
            "timeouts": [
                {
                    "idleAction": "lock",
                    "timeout": 600
                },
                {
                    "idleAction": "dpms off",
                    "returnAction": "dpms on",
                    "timeout": 750
                },
                {
                    "idleAction": [
                        "systemctl",
                        "suspend"
                    ],
                    "timeout": 900
                }
            ]
        },
        "mediaGifSpeedAdjustment": 125
    },
    "launcher": {
        "actionPrefix": "@",
        "actions": [
            {
                "command": [
                    "autocomplete",
                    "clip"
                ],
                "dangerous": false,
                "description": "Clipboard history",
                "enabled": true,
                "icon": "content_paste",
                "name": "Clipboard"
            },
            {
                "command": [
                    "autocomplete",
                    "calc"
                ],
                "dangerous": false,
                "description": "Do simple math equations",
                "enabled": true,
                "icon": "calculate",
                "name": "Calculator"
            },
            {
                "command": [
                    "autocomplete",
                    "emoji"
                ],
                "dangerous": false,
                "description": "Emoji Picker",
                "enabled": true,
                "icon": "mood",
                "name": "Emoji"
            },
            {
                "command": [
                    "autocomplete",
                    "wallpaper"
                ],
                "dangerous": false,
                "description": "Change the current wallpaper",
                "enabled": true,
                "icon": "image",
                "name": "Wallpaper"
            },
            {
                "command": [
                    "caelestia",
                    "wallpaper",
                    "-r"
                ],
                "dangerous": false,
                "description": "Switch to a random wallpaper",
                "enabled": true,
                "icon": "casino",
                "name": "Random"
            },
            {
                "command": [
                    "autocomplete",
                    "scheme"
                ],
                "dangerous": false,
                "description": "Change the current colour scheme",
                "enabled": true,
                "icon": "palette",
                "name": "Scheme"
            },
            {
                "command": [
                    "autocomplete",
                    "variant"
                ],
                "dangerous": false,
                "description": "Change the current scheme variant",
                "enabled": true,
                "icon": "colors",
                "name": "Variant"
            },
            {
                "command": [
                    "autocomplete",
                    "transparency"
                ],
                "dangerous": false,
                "description": "Change shell transparency",
                "enabled": false,
                "icon": "opacity",
                "name": "Transparency"
            },
            {
                "command": [
                    "setMode",
                    "light"
                ],
                "dangerous": false,
                "description": "Change the scheme to light mode",
                "enabled": false,
                "icon": "light_mode",
                "name": "Light"
            },
            {
                "command": [
                    "setMode",
                    "dark"
                ],
                "dangerous": false,
                "description": "Change the scheme to dark mode",
                "enabled": false,
                "icon": "dark_mode",
                "name": "Dark"
            },
            {
                "command": [
                    "caelestia",
                    "shell",
                    "drawers",
                    "toggle",
                    "session"
                ],
                "dangerous": false,
                "description": "Open session menu",
                "enabled": true,
                "icon": "power_settings_new",
                "name": "Session"
            },
            {
                "command": [
                    "systemctl",
                    "poweroff"
                ],
                "dangerous": true,
                "description": "Shutdown the system",
                "enabled": true,
                "icon": "power_settings_new",
                "name": "Shutdown"
            },
            {
                "command": [
                    "systemctl",
                    "reboot"
                ],
                "dangerous": true,
                "description": "Reboot the system",
                "enabled": true,
                "icon": "cached",
                "name": "Reboot"
            },
            {
                "command": [
                    "uwsm",
                    "stop"
                ],
                "dangerous": true,
                "description": "Log out of the current session",
                "enabled": true,
                "icon": "exit_to_app",
                "name": "Logout"
            },
            {
                "command": [
                    "loginctl",
                    "lock-session"
                ],
                "dangerous": false,
                "description": "Lock the current session",
                "enabled": true,
                "icon": "lock",
                "name": "Lock"
            },
            {
                "command": [
                    "systemctl",
                    "suspend"
                ],
                "dangerous": true,
                "description": "Suspend then hibernate",
                "enabled": true,
                "icon": "bedtime",
                "name": "Sleep"
            },
            {
                "command": [
                    "caelestia",
                    "shell",
                    "controlCenter",
                    "open"
                ],
                "dangerous": false,
                "description": "Configure the shell",
                "enabled": true,
                "icon": "settings",
                "name": "Settings"
            }
        ],
        "enableDangerousActions": false,
        "favouriteApps": [
            "com.mastermindzh.tidal-hifi",
            "org.telegram.desktop",
            "zen",
            "code",
            "vesktop",
            "steam"
        ],
        "hiddenApps": [
            "xfce4-about",
            "cmake-gui",
            "vim",
            "qvidcap",
            "qv4l2",
            "bssh",
            "bvnc",
            "avahi-discover",
            "thunar-settings",
            "org.kde.kdeconnect.nonplasma",
            "org.kde.kdeconnect.sms",
            "thunar-bulk-rename",
            "footclient",
            "foot-server",
            "mpv",
            "uuctl",
            "net.retrodeck.retrodeck.Configurator"
        ],
        "maxShown": 7,
        "maxWallpapers": 9,
        "showOnHover": false,
        "specialPrefix": "@",
        "useFuzzy": {
            "actions": false,
            "apps": true,
            "schemes": false,
            "variants": false,
            "wallpapers": true
        }
    },
    "notifs": {
        "actionOnClick": true,
        "defaultExpireTimeout": 3000
    },
    "osd": {
        "enableBrightness": true,
        "enableMicrophone": true,
        "enabled": true,
        "hideDelay": 1000
    },
    "paths": {
        "lyricsDir": "~/Music/lyrics",
        "wallpaperDir": "~/Pictures/Wallpaper"
    },
    "services": {
        "defaultPlayer": "Tidal",
        "playerAliases": [
            {
                "from": "tidal-hifi",
                "to": "Tidal"
            }
        ],
        "weatherLocation": "Orvieto"
    },
    "session": {
        "commands": {
            "automode": [
                "sh",
                "-c",
                "cortana api settings/automaticmode | grep -q On && val=0 || val=1; cortana api -val $val settings/automaticmode | cortana notify"
            ],
            "logout": [
                "uwsm",
                "stop"
            ],
            "reboot": [
                "sh",
                "-c",
                "cortana service &>/dev/null  && cortana api -cmd reboot computer | cortana notify || systemctl reboot"
            ],
            "shutdown": [
                "sh",
                "-c",
                "cortana service &>/dev/null  && cortana api -cmd shutdown computer | cortana notify || systemctl poweroff"
            ],
            "suspend": [
                "sh",
                "-c",
                "cortana service &>/dev/null  && cortana api -cmd reboot suspend | cortana notify || systemctl suspend"
            ],
            "windows": [
                "sh",
                "-c",
                "cortana service &>/dev/null  && cortana api -cmd system computer | cortana notify || systemctl reboot"
            ]
        }
    },
    "utilities": {
        "enabled": true,
        "maxToasts": 1,
        "quickToggles": [
            {
                "enabled": true,
                "id": "wifi"
            },
            {
                "enabled": true,
                "id": "bluetooth"
            },
            {
                "enabled": true,
                "id": "mic"
            },
            {
                "enabled": true,
                "id": "gameMode"
            },
            {
                "enabled": true,
                "id": "dnd"
            },
            {
                "enabled": false,
                "id": "vpn"
            },
            {
                "enabled": true,
                "id": "settings"
            }
        ],
        "toasts": {
            "kbLayoutChanged": false,
            "kbLimit": false,
            "nowPlaying": false
        },
        "vpn": {
            "enabled": false
        }
    }
}
